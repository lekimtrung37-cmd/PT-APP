rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTrainer() {
        return isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pt' || isAdmin());
    }
    
    function isTrainerSelf(trainerId) {
        return isTrainer() && request.auth.uid == trainerId;
    }

    function isAssignedTrainer(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
      return isTrainer() && userDoc.assignedPtId == request.auth.uid;
    }
    
    function isClientOfAssignedTrainer(trainerId) {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return userDoc.assignedPtId == trainerId;
    }

    // --- COLLECTION RULES ---

    match /site/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow write: if true; 
      allow read: if isAdmin();
    }
    
    match /publicExercises/{exerciseId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /trainerExercises/{trainerId}/{document=**} {
        allow read: if isOwner(trainerId) || isClientOfAssignedTrainer(trainerId);
        allow write: if isOwner(trainerId);
    }

    match /programTemplatesPublic/{templateId} {
        allow read: if isTrainer();
        allow write: if isAdmin();
        
        match /sessions/{sessionId} {
          allow read: if isTrainer();
          allow write: if isAdmin();
        }
    }
    
    match /programTemplatesTrainer/{trainerId} {
      allow read, write: if isTrainerSelf(trainerId);

      match /items/{templateId} {
        allow read, write: if isTrainerSelf(trainerId);

        match /sessions/{sessionId} {
           allow read, write: if isTrainerSelf(trainerId);
        }
      }
    }
    
    match /users/{userId}/notifications/{notificationId} {
        allow read: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin() || isClientOfAssignedTrainer(userId) || isAssignedTrainer(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      allow list: if isTrainer() || isAdmin();
      allow create: if isOwner(userId) || isAdmin() || (isTrainer() && request.resource.data.role == 'user' && request.resource.data.assignedPtId == request.auth.uid);
      allow update: if isOwner(userId) || isAdmin() || isAssignedTrainer(userId);
      allow delete: if isAdmin() || isAssignedTrainer(userId);

      match /workouts/{workoutId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
       match /completedWorkouts/{workoutId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /sessionHistory/{historyId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /checkins/{checkinId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /progressMetrics/{metricId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /personalRecords/{recordId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /progressPhotos/{photoId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
       match /nutritionPlan/{itemId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
      match /foodLogs/{logId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
        match /workoutFolders/{folderId} {
            allow read, write: if isOwner(userId);
        }
        match /workoutTemplates/{templateId} {
            allow read, write: if isOwner(userId);
        }
      match /habitTasks/{taskId} {
        allow read, write: if isOwner(userId) || isAssignedTrainer(userId) || isAdmin();
      }
    }

    match /trainerProfiles/{trainerId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isOwner(trainerId);
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
          // Trainer owns the appointment
          resource.data.trainerId == request.auth.uid
          // Client owns the appointment
          || resource.data.clientId == request.auth.uid
          // Trainer is the assigned PT for the client in the appointment
          || (
              isTrainer() && 
              resource.data.clientId != null && 
              get(/databases/$(database)/documents/users/$(resource.data.clientId)).data.assignedPtId == request.auth.uid
          )
      );

      allow create: if isSignedIn() && (
        // Trainer can create for themselves
        (isTrainer() && request.resource.data.trainerId == request.auth.uid) ||
        // Client can create for themselves
        (request.resource.data.clientId == request.auth.uid && request.resource.data.createdBy == request.auth.uid)
      );

      allow update: if isSignedIn() && (
        // Trainer can update their own appointments
        resource.data.trainerId == request.auth.uid ||
        // Client can update appointments they created
        (resource.data.clientId == request.auth.uid && resource.data.createdBy == request.auth.uid)
      );
      
      allow delete: if isSignedIn() && (
         // Trainer can delete their own appointments
        resource.data.trainerId == request.auth.uid ||
        // Client can delete appointments they created
        (resource.data.clientId == request.auth.uid && resource.data.createdBy == request.auth.uid)
      );
    }
    
    match /conversations/{conversationId} {
      // Allow a user to check for existence (get) and read a conversation they are part of.
      allow get: if (isSignedIn() && (request.auth.uid in conversationId.split('_'))) || isAdmin();
      
      // Explicitly disallow listing all conversations to prevent data leaks.
      allow list: if isAdmin();
      
      // Allow a user to create a conversation if they are a participant and the ID is correctly formed.
      allow create: if isSignedIn() 
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.participantIds is list
                    && request.resource.data.participantIds.size() == 2;
      
      // Allow a participant to update a conversation (e.g., lastMessage), but not the participants list.
      allow update: if (isSignedIn() && request.auth.uid in resource.data.participantIds) 
                    && request.resource.data.participantIds == resource.data.participantIds;

      allow delete: if isAdmin();

      match /messages/{messageId} {
         // Allow participants to read and create messages.
         allow read, create: if isSignedIn() 
                              && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        
         // Only admins can alter existing messages.
         allow update, delete: if isAdmin();
      }
    }
  }
}